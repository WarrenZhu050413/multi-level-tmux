#!/bin/bash
# worktree-tmux — Create 4 git worktrees in a 2x2 tmux session
# Usage: worktree-tmux [--help] [namespace] [level]

set -euo pipefail
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat << 'EOF'
worktree-tmux — Create 4 git worktrees in a 2x2 tmux session

USAGE:
    worktree-tmux [namespace] [level]

ARGUMENTS:
    namespace    Identifier for worktrees (default: timestamp)
    level        Tmux level 1-9 (default: auto-detect from parent)

LAYOUT:
    ┌─────────┬─────────┐
    │ tree-1  │ tree-2  │
    ├─────────┼─────────┤
    │ tree-3  │ tree-4  │
    └─────────┴─────────┘

EXAMPLES:
    worktree-tmux backend        # Named namespace, auto level
    worktree-tmux backend 2      # Named namespace, Level 2
EOF
    exit 0
fi

git rev-parse --git-dir > /dev/null 2>&1 || die "Not in a git repository"

dir=$(basename "$PWD")
namespace="${1:-$(date +%s)}"
level_arg="${2:-}"
session_name="${dir}-${namespace}"

tmux has-session -t "$session_name" 2>/dev/null &&
    die "Session '$session_name' exists. Attach: tmux attach -t $session_name"

# Cleanup helper for error paths
cleanup_worktrees() {
    for i in {1..4}; do
        git worktree remove "../${dir}-${namespace}-$i" 2>/dev/null || true
    done
}

# Determine level
if [[ -n "$level_arg" ]]; then
    [[ "$level_arg" =~ ^[1-9]$ ]] || { cleanup_worktrees; die "Level must be 1-9, got '$level_arg'"; }
    new_level="$level_arg"
else
    if [[ -n "${TMUX:-}" ]]; then
        parent=$(detect_session_level "$(tmux display-message -p '#S' 2>/dev/null)")
        new_level=$((parent + 1))
        [[ $new_level -le 9 ]] || { cleanup_worktrees; die "Already at Level 9"; }
    else
        new_level=1
    fi
fi

# Create worktrees
echo "Creating worktrees ($namespace)..."
for i in {1..4}; do
    branch="${dir}-${namespace}-$i"
    path="../${dir}-${namespace}-$i"
    if git show-ref --verify --quiet "refs/heads/$branch"; then
        echo "  $path (existing branch)"
        git worktree add "$path" "$branch"
    else
        echo "  $path (new branch)"
        git worktree add "$path" -b "$branch"
    fi
done

# Create session
echo "Creating session '$session_name' at Level $new_level..."
tmux new-session -d -s "$session_name" -c "../${dir}-${namespace}-1"
tmux set-option -t "$session_name" @session_level "$new_level"
tmux set-option -t "$session_name" status-right \
    "#(TMUX_SESSION=#S $DMT_DIR/core/tmux-level-status --visual) #{?client_prefix,[ACTIVE],} | %l:%M%p"

# Set prefix based on active level
current_active=$(active_level)
if [[ "$new_level" == "$current_active" ]]; then
    tmux set-option -t "$session_name" prefix "$PRIMARY_PREFIX"
    tmux set-option -t "$session_name" key-table root
else
    tmux set-option -t "$session_name" prefix "$SECONDARY_PREFIX"
    tmux set-option -t "$session_name" key-table off
fi

# 2x2 pane layout
tmux split-window -h -t "$session_name" -c "../${dir}-${namespace}-2"
tmux select-pane -t "${session_name}.0"
tmux split-window -v -t "$session_name" -c "../${dir}-${namespace}-3"
tmux select-pane -t "${session_name}.2"
tmux split-window -v -t "$session_name" -c "../${dir}-${namespace}-4"
tmux select-layout -t "$session_name" tiled
tmux attach-session -t "$session_name"
