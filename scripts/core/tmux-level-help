#!/bin/bash
# tmux-level-help — Show navigation commands for current level
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

level=$(active_level)
key="${PRIMARY_PREFIX#*-}"

cat << EOF
=== TMUX LEVEL $level HELP ===
Primary Prefix: $PRIMARY_PREFIX (active sessions)
Secondary Prefix: $SECONDARY_PREFIX (passthrough)

NAVIGATION:
  $PRIMARY_PREFIX !       → Jump to Level 1
  Ctrl+P         → Up one level
  Ctrl+N         → Down one level
  $PRIMARY_PREFIX x       → Copy mode

DIRECT JUMPS:
  $PRIMARY_PREFIX ! @ # \$ % ^ & * ( → Levels 1-9

STATUS BAR:
  tmux-level-status --visual   → [L3:$key ●●●○○○○○○]
  tmux-level-status --compact  → [L3:$key]
  tmux-level-status --help     → Format options

If stuck: $DMT_DIR/core/tmux-level-reset
EOF
