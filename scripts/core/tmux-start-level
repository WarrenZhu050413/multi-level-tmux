#!/bin/bash
# tmux-start-level — Start tmux session with level identity (1-9)
# Usage: tmux-start-level [level] [tmux-new-session-options...]

set -euo pipefail
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat << 'EOF'
tmux-start-level — Start tmux session with level identity (1-9)

USAGE:
    tmux-start-level [level] [tmux-options...]

ARGUMENTS:
    level           Session level (1-9); auto-increments from parent if omitted
    tmux-options    Any flags for 'tmux new-session'

EXAMPLES:
    tmux-start-level                           # Auto-select next level
    tmux-start-level 1                         # Basic Level 1 session
    tmux-start-level 2 -s project              # Named Level 2 session
    tmux-start-level 3 -s work -c ~/projects   # Level 3, named, specific dir
    tmux-start-level -s myproject              # Auto-level with session name

NOTES:
    - Sessions start in passthrough mode; use navigation to activate
    - Use prefix + !@#$%^&*( to navigate to levels 1-9
EOF
    exit 0
fi

# Auto-detect next level from parent session
find_next_level() {
    local parent=0
    if [[ -n "${TMUX:-}" ]]; then
        local session
        session=$(tmux display-message -p '#S' 2>/dev/null || echo '')
        if [[ -n "$session" ]]; then
            local detected
            detected=$(detect_session_level "$session")
            [[ "$detected" =~ ^[1-9]$ ]] && parent="$detected"
        fi
    fi
    echo $(( (parent % 9) + 1 ))
}

# Parse level: explicit first arg, or auto-increment
if [[ $# -gt 0 && "$1" =~ ^[1-9]$ ]]; then
    level="$1"; shift
else
    level=$(find_next_level)
    echo "Auto-selecting Level $level"
fi

# Determine prefix based on current active level
current_active=$(active_level)
if [[ "$level" -eq "$current_active" ]]; then
    prefix="$PRIMARY_PREFIX"; table="root"
    echo "Starting Level $level session (ACTIVE)"
else
    prefix="$SECONDARY_PREFIX"; table="off"
    echo "Starting Level $level session (passthrough)"
fi

exec tmux new-session "$@" \; \
    set-option @session_level "$level" \; \
    set-option status-right "#(TMUX_SESSION=#S $DMT_DIR/core/tmux-level-status --visual) #{?client_prefix,[ACTIVE],} | %l:%M%p" \; \
    set-option prefix "$prefix" \; \
    set-option key-table "$table"
