#!/bin/bash
# tmux-level-push — push current pane into a nested deeper-level session
#
# Preserves the original process: swaps it into the nested session,
# then replaces the outer pane with a nested tmux client (portal).
#
# Bind in tmux.conf:
#   bind D run-shell "~/.local/bin/tmux-multilevel/core/tmux-level-push '#{pane_id}' '#S'"

set -euo pipefail
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

pane_id="${1:?usage: tmux-level-push PANE_ID SESSION_NAME}"
session="${2:?usage: tmux-level-push PANE_ID SESSION_NAME}"

level=$(detect_session_level "$session")
next=$(( (level % 9) + 1 ))

# Unique session name
new="${session}-L${next}"
n=0
while tmux has-session -t "$new" 2>/dev/null; do
    n=$((n + 1))
    new="${session}-L${next}-${n}"
done

# 1. Create nested session (detached, with throwaway shell)
tmux new-session -d -s "$new" -e MT_LEVEL=$next
sleep 0.3
throwaway=$(tmux list-panes -t "${new}:" -F '#{pane_id}' | head -1)

# 2. Swap: our pane goes into the nested session, throwaway comes to our position
tmux swap-pane -s "$pane_id" -t "$throwaway"

# 3. Replace the throwaway (now at our old position) with a nested tmux client
tmux respawn-pane -t "$throwaway" -k \
    "TMUX='' tmux attach -t '${new}'; exec \$SHELL"
