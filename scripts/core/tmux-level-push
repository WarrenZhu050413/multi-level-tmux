#!/bin/bash
# tmux-level-push — nest a deeper-level tmux session inside the current pane
#
# The pane stays in the original session but now displays a nested tmux
# at level+1. Detach from the nested session to return to the outer shell.
#
# Bind in tmux.conf:
#   bind D run-shell "~/.local/bin/tmux-multilevel/core/tmux-level-push '#{pane_id}' '#S'"

set -euo pipefail
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

pane_id="${1:?usage: tmux-level-push PANE_ID SESSION_NAME}"
session="${2:?usage: tmux-level-push PANE_ID SESSION_NAME}"

level=$(detect_session_level "$session")
next=$(( (level % 9) + 1 ))

# Pick unique session name
new="${session}-L${next}"
n=0
while tmux has-session -t "$new" 2>/dev/null; do
    n=$((n + 1))
    new="${session}-L${next}-${n}"
done

# Launch nested tmux session inside the current pane
tmux send-keys -t "$pane_id" "unset TMUX && tmux new-session -e MT_LEVEL=${next} -s '${new}'" Enter
