#!/bin/bash
# tmux-goto-level — Navigate to a specific level (1-9)
# Usage: tmux-goto-level <1-9>

set -euo pipefail
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

[[ $# -eq 1 ]] || die "Usage: tmux-goto-level <1-9>"
[[ "$1" =~ ^[1-9]$ ]] || die "Level must be 1-9, got '$1'"
target="$1"

# Step 1: Update global navigation state
tmux set-option -g @active_level "$target" 2>/dev/null || die "Failed to set @active_level"
tmux display-message "Navigating to Level $target..." 2>/dev/null || true

# Step 2: Re-evaluate every session — activate matching, passthrough the rest
activated=0  passthrough=0
while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    level=$(detect_session_level "$session")

    if [[ "$level" -eq "$target" ]]; then
        if tmux set-option -t "$session" prefix "$PRIMARY_PREFIX" 2>/dev/null &&
           tmux set-option -t "$session" key-table root 2>/dev/null; then
            activated=$((activated + 1))
        fi
    else
        if tmux set-option -t "$session" prefix "$SECONDARY_PREFIX" 2>/dev/null &&
           tmux set-option -t "$session" key-table off 2>/dev/null; then
            passthrough=$((passthrough + 1))
        fi
    fi
done < <(tmux list-sessions -F '#S' 2>/dev/null || true)

# Step 3: Feedback
if [[ $activated -eq 0 ]]; then
    tmux display-message "Level $target: no sessions (use tmux-start-level $target)" 2>/dev/null || true
else
    tmux display-message "Level $target active ($activated active, $passthrough passthrough)" 2>/dev/null || true
fi

# Step 4: Refresh & persist
tmux refresh-client -S 2>/dev/null || true
echo "$target" > ~/.tmux_level_state 2>/dev/null || true
