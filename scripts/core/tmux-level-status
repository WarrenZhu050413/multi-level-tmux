#!/bin/bash
# tmux-level-status — Format level indicator for tmux status bar
# Usage: tmux-level-status [--compact|--full|--minimal|--visual|--help]

set -euo pipefail
source "$HOME/.local/bin/tmux-multilevel/lib.sh"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat << 'EOF'
tmux-level-status — Format level indicator for tmux status bar

FORMATS:
    --compact (default)  [session:L2 ✓] or [session:L2→L3]
    --full              [session:L2:Ctrl+X ✓]
    --minimal           [session:2✓] or [session:2→3]
    --visual            [session:L2 ✓] [●●○○○○○○○]

USAGE IN STATUS BAR:
    set-option -g status-right "#(tmux-level-status --visual) | %l:%M%p"
EOF
    exit 0
fi

session="${TMUX_SESSION:-$(tmux display-message -p '#S' 2>/dev/null || echo default)}"
slevel=$(detect_session_level "$session")
alevel=$(active_level)
is_active=$([[ "$slevel" == "$alevel" ]] && echo true || echo false)

# Build visual dots: ●●●○○○○○○
# Uses printf loop instead of tr — tr corrupts multi-byte UTF-8 chars
dots() {
    local i
    for ((i = 0; i < $1; i++)); do printf '●'; done
    for ((i = $1; i < 9; i++)); do printf '○'; done
}

format="${1:---compact}"
# Use ${var} braces everywhere — bare $var before Unicode (→, ✓) confuses bash
case "$format" in
    --compact)
        if $is_active; then out="[${session}:L${slevel} ✓]"
        else out="[${session}:L${slevel}→L${alevel}]"; fi ;;
    --full)
        if $is_active; then out="[${session}:L${slevel}:Ctrl+${PRIMARY_PREFIX#C-} ✓]"
        else out="[${session}:L${slevel}→L${alevel}]"; fi ;;
    --minimal)
        if $is_active; then out="[${session}:${slevel}✓]"
        else out="[${session}:${slevel}→${alevel}]"; fi ;;
    --visual)
        d=$(dots "$alevel")
        if $is_active; then out="[${session}:L${slevel} ✓] [${d}]"
        else out="[${session}:L${slevel}→L${alevel}] [${d}]"; fi ;;
    *)
        if $is_active; then out="[${session}:L${slevel} ✓]"
        else out="[${session}:L${slevel}→L${alevel}]"; fi ;;
esac

# Colorize: mint green (active) / soft blue (passthrough)
if $is_active; then
    echo "#[fg=colour156]${out}#[default]"
else
    echo "#[fg=colour67]${out}#[default]"
fi
